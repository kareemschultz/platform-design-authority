{
  "name": "docs",
  "version": "0.0.4",
  "private": true,
  "scripts": {
    "build": "next build --webpack",
    "check-content": "bun run scripts/check-content.mjs",
    "dev": "next dev --webpack --port=4000",
    "start": "next start",
    "check-types": "bun run check-content && next typegen && fumadocs-mdx && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "biome check",
    "format": "biome format --write"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "cnfast": "^0.0.8",
    "flexsearch": "^0.8.212",
    "fumadocs-core": "16.11.3",
    "fumadocs-mdx": "15.1.0",
    "fumadocs-ui": "npm:@fumadocs/base-ui@16.11.3",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "lucide-react": "1.24.0",
    "next": "16.2.11",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-rehype": "^11.1.2",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/hast": "^3.0.4",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "postcss": "8.5.17",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  }
}
