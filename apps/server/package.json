{
  "name": "server",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs",
    "start:node": "node dist/node.mjs",
    "test": "bun test src/*.test.ts",
    "db:migrate": "bun run composition/migrate.ts",
    "db:test": "bun test composition/*.integration.test.ts",
    "db:test:node": "node node_modules/tsx/dist/cli.mjs composition/persistence.node-check.ts && node node_modules/tsx/dist/cli.mjs composition/ws1-critical.node-check.ts",
    "e2e:seed": "bun run composition/web-experience.fixture.ts"
  },
  "dependencies": {
    "@meridian/contracts-capabilities": "workspace:*",
    "@hono/node-server": "2.0.8",
    "@meridian/contracts-permissions": "workspace:*",
    "@meridian/contracts-platform-api": "workspace:*",
    "@meridian/domain-catalog": "workspace:*",
    "@meridian/domain-inventory": "workspace:*",
    "@meridian/domain-party": "workspace:*",
    "@meridian/domain-pos": "workspace:*",
    "@meridian/engine-pricing": "workspace:*",
    "@meridian/engine-tax": "workspace:*",
    "@meridian/persistence-catalog-postgres": "workspace:*",
    "@meridian/persistence-inventory-postgres": "workspace:*",
    "@meridian/persistence-pos-postgres": "workspace:*",
    "@meridian/platform-authorization": "workspace:*",
    "@meridian/platform-entitlements": "workspace:*",
    "@meridian/platform-identity": "workspace:*",
    "@meridian/persistence-platform-events-postgres": "workspace:*",
    "@meridian/persistence-platform-audit-postgres": "workspace:*",
    "@meridian/persistence-platform-entitlements-postgres": "workspace:*",
    "@meridian/persistence-platform-identity-postgres": "workspace:*",
    "@meridian/persistence-platform-import-export-postgres": "workspace:*",
    "@meridian/persistence-platform-numbering-postgres": "workspace:*",
    "@meridian/persistence-platform-tenancy-postgres": "workspace:*",
    "@meridian/persistence-party-postgres": "workspace:*",
    "@meridian/platform-events": "workspace:*",
    "@meridian/platform-import-export": "workspace:*",
    "@meridian/platform-numbering": "workspace:*",
    "@meridian/platform-audit": "workspace:*",
    "@meridian/platform-tenancy": "workspace:*",
    "@meridian/tooling-env": "workspace:*",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "hono": "catalog:",
    "pg": "8.22.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@meridian/contracts-events": "workspace:*",
    "@meridian/tooling-config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/pg": "catalog:",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "drizzle-orm": "catalog:",
    "tsdown": "^0.22.3",
    "tsx": "4.21.0",
    "typescript": "^6"
  }
}
