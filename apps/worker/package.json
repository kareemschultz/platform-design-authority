{
  "name": "worker",
  "private": true,
  "type": "module",
  "main": "composition/main.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "db:test": "bun test composition/*.integration.test.ts",
    "dev": "bun run --hot composition/main.ts",
    "start": "bun run dist/main.mjs",
    "start:node": "node dist/main.mjs",
    "test": "bun test src/*.test.ts",
    "test:node": "node node_modules/tsx/dist/cli.mjs composition/delivery.node-check.ts"
  },
  "dependencies": {
    "@meridian/persistence-catalog-postgres": "workspace:*",
    "@meridian/persistence-inventory-postgres": "workspace:*",
    "@meridian/persistence-platform-events-postgres": "workspace:*",
    "@meridian/platform-events": "workspace:*",
    "@meridian/tooling-env": "workspace:*",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@meridian/tooling-config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/pg": "catalog:",
    "tsdown": "^0.22.3",
    "tsx": "4.21.0",
    "typescript": "^6"
  }
}
