{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs",
    "start:node": "node dist/node.mjs"
  },
  "dependencies": {
    "@hono/node-server": "2.0.8",
    "@meridian/api": "workspace:*",
    "@meridian/auth": "workspace:*",
    "@meridian/db": "workspace:*",
    "@meridian/env": "workspace:*",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@meridian/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.22.3",
    "typescript": "^6"
  }
}
