{
  "name": "meridian",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "packages/*/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "@types/bun": "1.3.14",
      "hono": "4.12.29",
      "@orpc/server": "1.14.7",
      "@orpc/openapi": "1.14.7",
      "@orpc/zod": "1.14.7",
      "better-auth": "1.6.23",
      "lucide-react": "1.24.0",
      "next-themes": "^0.4.6",
      "sonner": "^2.0.7",
      "@orpc/tanstack-query": "1.14.7",
      "@orpc/client": "1.14.7",
      "@tanstack/react-query": "^5.101.2",
      "@tanstack/react-form": "^1.33.0",
      "@tailwindcss/postcss": "^4.3.2",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.3.2",
      "@better-auth/expo": "1.6.23",
      "drizzle-orm": "^0.45.2",
      "@types/pg": "^8.20.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:native": "turbo run dev -F native",
    "dev:web": "turbo run dev -F web",
    "dev:server": "turbo run dev -F server",
    "db:push": "turbo run db:push -F @meridian/db",
    "db:studio": "turbo run db:studio -F @meridian/db",
    "db:generate": "turbo run db:generate -F @meridian/db",
    "db:migrate": "turbo run db:migrate -F @meridian/db",
    "db:start": "docker compose up -d postgres",
    "db:watch": "docker compose up postgres",
    "db:stop": "docker compose stop postgres",
    "db:down": "docker compose down postgres",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "test": "turbo run test",
    "check": "ultracite check apps packages",
    "fix": "ultracite fix apps packages",
    "contracts:generate": "python scripts/generate_contracts.py",
    "contracts:check": "python scripts/generate_contracts.py --check"
  },
  "dependencies": {
    "@meridian/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "postcss": "8.5.17",
    "uuid": "14.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@meridian/config": "workspace:*",
    "@types/bun": "catalog:",
    "micromark-util-decode-numeric-character-reference": "2.0.2",
    "turbo": "^2.10.2",
    "typescript": "^6",
    "ultracite": "7.9.3"
  },
  "packageManager": "bun@1.3.14"
}
