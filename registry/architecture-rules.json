{
  "schema_version": "1.0.0",
  "status": "draft",
  "source_document": "docs/blueprint/14-Engineering/ARCHITECTURE_DEPENDENCY_RULES.md",
  "package_families": [
    {
      "id": "applications",
      "globs": [
        "apps/*"
      ],
      "may_depend_on": [
        "foundation",
        "contracts",
        "platform-clients",
        "ui-web",
        "ui-native",
        "design-tokens",
        "tooling"
      ]
    },
    {
      "id": "platform-clients",
      "globs": [
        "packages/platform-clients/*"
      ],
      "may_depend_on": [
        "foundation",
        "contracts"
      ]
    },
    {
      "id": "foundation",
      "globs": [
        "packages/foundation/*"
      ],
      "may_depend_on": []
    },
    {
      "id": "platform",
      "globs": [
        "packages/platform/*"
      ],
      "may_depend_on": [
        "foundation",
        "contracts",
        "tooling"
      ]
    },
    {
      "id": "engines",
      "globs": [
        "packages/engines/*"
      ],
      "may_depend_on": [
        "foundation",
        "contracts",
        "platform",
        "tooling"
      ]
    },
    {
      "id": "domains",
      "globs": [
        "packages/domains/*"
      ],
      "may_depend_on": [
        "foundation",
        "contracts",
        "platform",
        "engines",
        "tooling"
      ]
    },
    {
      "id": "contracts",
      "globs": [
        "packages/contracts/*"
      ],
      "may_depend_on": [
        "foundation"
      ]
    },
    {
      "id": "persistence",
      "globs": [
        "packages/persistence/*"
      ],
      "may_depend_on": [
        "foundation",
        "contracts",
        "platform",
        "engines",
        "domains"
      ]
    },
    {
      "id": "ui-web",
      "globs": [
        "packages/ui-web/*"
      ],
      "may_depend_on": [
        "foundation",
        "contracts",
        "design-tokens"
      ]
    },
    {
      "id": "ui-native",
      "globs": [
        "packages/ui-native/*"
      ],
      "may_depend_on": [
        "foundation",
        "contracts",
        "design-tokens"
      ]
    },
    {
      "id": "design-tokens",
      "globs": [
        "packages/design-tokens/*"
      ],
      "may_depend_on": []
    },
    {
      "id": "integrations",
      "globs": [
        "packages/integrations/*"
      ],
      "may_depend_on": [
        "foundation",
        "contracts",
        "platform"
      ]
    },
    {
      "id": "tooling",
      "globs": [
        "packages/tooling/*"
      ],
      "may_depend_on": [
        "foundation"
      ]
    }
  ],
  "forbidden_patterns": [
    {
      "id": "cross-domain-repository",
      "description": "A domain cannot import another domain repository or persistence package.",
      "pattern": "packages/domains/* -> packages/domains/*/(repository|persistence|migrations)"
    },
    {
      "id": "database-outside-persistence",
      "description": "Database clients are limited to approved persistence packages, except that registered composition-root paths (`requirements.composition_roots`) may import a database client solely to construct the single process pool/connection and inject it through published ports, per ADR-0027. No other path may import a database client.",
      "pattern": "**/!(persistence)/** -> database-client",
      "except": [
        "apps/*/composition",
        "packages/tooling/composition/*"
      ]
    },
    {
      "id": "provider-type-leak",
      "description": "Provider SDK types cannot appear in domain contracts.",
      "pattern": "packages/contracts/** -> provider-sdk"
    },
    {
      "id": "business-rule-in-ui",
      "description": "UI packages cannot own authoritative business rules or persistence.",
      "pattern": "packages/ui-*/** -> (database|domain-repository)"
    },
    {
      "id": "plan-name-authorization",
      "description": "Commercial plan names cannot appear in authorization logic.",
      "pattern": "authorization -> commercial-plan-name"
    },
    {
      "id": "feature-flag-entitlement",
      "description": "Feature flags cannot create entitlement access.",
      "pattern": "entitlement -> feature-flag-key"
    },
    {
      "id": "better-auth-table-leak",
      "description": "Business domains cannot import Better Auth tables or persistence models.",
      "pattern": "packages/domains/** -> better-auth/(tables|schema|persistence)"
    },
    {
      "id": "ai-repository-import",
      "description": "AI prompt and tool packages cannot import repositories directly.",
      "pattern": "packages/ai/** -> **/(repository|persistence)"
    },
    {
      "id": "domain-cloud-infrastructure",
      "description": "Domain packages cannot import self-hosted or cloud-specific infrastructure code.",
      "pattern": "packages/domains/** -> (cloud-provider|self-hosted-infrastructure)"
    },
    {
      "id": "bun-runtime-leak",
      "description": "Runtime-neutral core packages cannot import Bun globals or Bun-only APIs.",
      "pattern": "packages/(foundation|contracts|platform|engines|domains)/** -> bun-runtime"
    },
    {
      "id": "hono-context-leak",
      "description": "Hono request and context objects remain in application transport adapters.",
      "pattern": "packages/**/!(transport|composition)/** -> hono-context"
    },
    {
      "id": "orpc-transport-leak",
      "description": "oRPC transport objects remain in application transport adapters or generated-client boundaries.",
      "pattern": "packages/**/!(transport|generated-client)/** -> orpc-transport"
    },
    {
      "id": "database-adapter-contract-leak",
      "description": "Contracts and authorization policies cannot import database adapters.",
      "pattern": "packages/**/(contracts|authorization)/** -> database-adapter"
    },
    {
      "id": "persistence-cross-owner-import",
      "description": "An owner-specific persistence package cannot import another owner's repository, private schema, tables, or migrations.",
      "pattern": "packages/persistence/<owner> -> non-owner/(repository|schema|tables|migrations)"
    },
    {
      "id": "connection-lifecycle-outside-composition",
      "description": "Pool creation, shutdown, and connection-bearing environment reads belong to registered composition roots.",
      "pattern": "**/!(composition)/** -> (pool-construction|pool-shutdown|connection-environment)"
    }
  ],
  "requirements": {
    "single_table_owner": true,
    "single_migration_owner": true,
    "circular_dependencies": "prohibited_without_exception",
    "exceptions_require_expiry": true,
    "composition_roots": [
      "apps/*/composition",
      "packages/tooling/composition/*"
    ],
    "composition_root_may_depend_on": [
      "persistence",
      "platform",
      "engines",
      "domains"
    ],
    "persistence_requires_owner": true,
    "family_grants_are_contract_only": true,
    "runtime_neutral_families": [
      "foundation",
      "contracts",
      "platform",
      "engines",
      "domains"
    ]
  },
  "persistence_owners": [
    {
      "id": "platform-identity-postgres",
      "package": "packages/persistence/platform-identity-postgres",
      "package_name": "@meridian/persistence-platform-identity-postgres",
      "owner": "platform.identity",
      "owner_package": "@meridian/platform-identity",
      "tables": [
        "account",
        "invitation",
        "member",
        "organization",
        "passkey",
        "session",
        "two_factor",
        "user",
        "verification"
      ],
      "migration_directory": "packages/persistence/platform-identity-postgres/src/migrations"
    },
    {
      "id": "platform-tenancy-postgres",
      "package": "packages/persistence/platform-tenancy-postgres",
      "package_name": "@meridian/persistence-platform-tenancy-postgres",
      "owner": "platform.tenancy",
      "owner_package": "@meridian/platform-tenancy",
      "tables": [
        "platform_active_context",
        "platform_location",
        "platform_membership",
        "platform_membership_invitation",
        "platform_organization",
        "platform_tenant",
        "platform_tenancy_command_receipt"
      ],
      "migration_directory": "packages/persistence/platform-tenancy-postgres/src/migrations"
    },
    {
      "id": "platform-events-postgres",
      "package": "packages/persistence/platform-events-postgres",
      "package_name": "@meridian/persistence-platform-events-postgres",
      "owner": "platform.events",
      "owner_package": "@meridian/platform-events",
      "tables": [
        "platform_event_outbox"
      ],
      "migration_directory": "packages/persistence/platform-events-postgres/src/migrations"
    }
  ],
  "exceptions": []
}
