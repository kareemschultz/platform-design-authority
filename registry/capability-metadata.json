{
  "schema_version": "1.0.0",
  "status": "draft",
  "description": "Governed metadata overlay for capability packaging, offline posture, and dependencies. Explicit capability overrides take precedence over namespace defaults.",
  "test_dimension_defaults": {
    "full": {},
    "prototype": {},
    "seam": {
      "offline_and_degraded": {"status":"deferred-by-depth","reason":"The seam must define degraded behavior, but executable offline behavior belongs to a deeper implementation depth."},
      "accessibility_and_responsive": {"status":"not-applicable","reason":"A contract seam has no rendered user interface; consuming interfaces retain their own accessibility obligations."},
      "performance_and_capacity": {"status":"deferred-by-depth","reason":"The seam carries provisional limits; measured capacity evidence is required when an implementation is selected."}
    }
  },
  "namespace_defaults": {
    "platform": {"packaging_class":"CorePlatform","offline":"VariesByCapability"},
    "engine": {"packaging_class":"SharedEngine","offline":"OnlineOrSeam"},
    "party": {"packaging_class":"CorePlatform","offline":"ReadLimited"},
    "payment": {"packaging_class":"SharedEngine","offline":"ProviderAndPolicyDependent"},
    "fiscalization": {"packaging_class":"JurisdictionConditional","offline":"JurisdictionDependent"},
    "security": {"packaging_class":"CorePlatform","offline":"VariesByCapability"},
    "developer": {"packaging_class":"DeveloperPlatform","offline":"OnlineOnly"},
    "marketplace": {"packaging_class":"Marketplace","offline":"OnlineOnly"},
    "commercial": {"packaging_class":"CommercialControlPlane","offline":"OnlineOnly"},
    "commerce": {"packaging_class":"BusinessDomain","offline":"VariesByCapability"},
    "catalog": {"packaging_class":"BusinessDomain","offline":"ReadWriteLimited"},
    "inventory": {"packaging_class":"BusinessDomain","offline":"ReadWriteLimited"},
    "crm": {"packaging_class":"BusinessDomain","offline":"ReadLimited"},
    "finance": {"packaging_class":"BusinessDomain","offline":"OnlineOrExport"}
  },
  "capabilities": {
    "platform.tenancy": {"offline":"OnlineOnly","dependencies":[]},
    "platform.organizations": {"offline":"ReadLimited","dependencies":["platform.tenancy"]},
    "party.records": {"offline":"ReadWriteLimited","dependencies":["platform.tenancy"]},
    "platform.identity": {"offline":"OnlineOnly","dependencies":["platform.authentication","party.records"]},
    "platform.authentication": {"offline":"OnlineOnly","dependencies":["platform.tenancy"]},
    "platform.authorization": {"offline":"LeaseEvaluated","dependencies":["platform.identity"]},
    "platform.entitlements": {"offline":"LeaseEvaluated","dependencies":["platform.authorization"]},
    "platform.audit": {"offline":"QueueAndSync","dependencies":["platform.identity"]},
    "platform.events": {"offline":"ServerOnly","dependencies":["platform.audit"]},
    "platform.numbering": {"offline":"AllocatedRanges","dependencies":["platform.tenancy"]},
    "platform.devices": {"offline":"Core","dependencies":["platform.identity","platform.authorization"]},
    "platform.offline-sync": {"offline":"Core","dependencies":["platform.devices","platform.events","platform.audit"]},
    "engine.pricing": {"offline":"SnapshotAndPolicy","dependencies":["catalog.products"]},
    "engine.tax": {"offline":"VersionedSnapshot","dependencies":["platform.reference-data"]},
    "engine.payments": {"offline":"ProviderAndPolicyDependent","dependencies":["platform.secrets","platform.audit"]},
    "payment.intents": {"offline":"QueueOrOnline","dependencies":["engine.payments"]},
    "payment.provider-adapters": {"offline":"OnlineOnly","dependencies":["platform.secrets"]},
    "payment.authorization": {"offline":"ProviderAndPolicyDependent","dependencies":["payment.intents"]},
    "payment.capture": {"offline":"ProviderAndPolicyDependent","dependencies":["payment.authorization"]},
    "payment.refunds": {"offline":"OnlineOnly","dependencies":["payment.intents"]},
    "payment.reversals": {"offline":"OnlineOnly","dependencies":["payment.intents"]},
    "payment.settlement": {"offline":"OnlineOnly","dependencies":["payment.provider-adapters"]},
    "payment.reconciliation": {"offline":"OnlineOnly","dependencies":["payment.settlement"]},
    "commerce.pos": {"offline":"Core","dependencies":["catalog.products","inventory.stock-balances","engine.pricing","engine.tax"]},
    "commerce.register-management": {"offline":"Core","dependencies":["commerce.pos"]},
    "commerce.shift-management": {"offline":"Core","dependencies":["commerce.register-management"]},
    "commerce.cash-management": {"offline":"Core","dependencies":["commerce.shift-management"]},
    "commerce.returns": {"offline":"Limited","dependencies":["commerce.pos","inventory.stock-ledger"]},
    "commerce.exchanges": {"offline":"Limited","dependencies":["commerce.returns"]},
    "commerce.refunds": {"offline":"OnlineOrStoredValue","dependencies":["commerce.returns","payment.refunds"]},
    "commerce.receipts": {"offline":"Core","dependencies":["platform.numbering","engine.documents"]},
    "commerce.stored-value": {"offline":"AllowanceLimited","dependencies":["commerce.stored-value-ledger","security.risk-policies"]},
    "commerce.stored-value-ledger": {"offline":"QueueAndReconcile","dependencies":["platform.audit"]},
    "catalog.products": {"offline":"ReadWriteLimited","dependencies":["platform.extensible-metadata"]},
    "catalog.variants": {"offline":"ReadWriteLimited","dependencies":["catalog.products"]},
    "catalog.identifiers": {"offline":"CoreLookup","dependencies":["catalog.products"]},
    "catalog.barcodes": {"offline":"CoreLookup","dependencies":["catalog.identifiers"]},
    "inventory.stock-ledger": {"offline":"QueueAndReconcile","dependencies":["catalog.products"]},
    "inventory.stock-balances": {"offline":"CachedProjection","dependencies":["inventory.stock-ledger"]},
    "inventory.availability": {"offline":"CachedProjection","dependencies":["inventory.stock-balances"]},
    "inventory.adjustments": {"offline":"Limited","dependencies":["inventory.stock-ledger"]},
    "inventory.transfers": {"offline":"Limited","dependencies":["inventory.stock-ledger"]},
    "inventory.counts": {"offline":"Core","dependencies":["inventory.stock-ledger"]},
    "developer.webhooks": {"offline":"OnlineOnly","dependencies":["platform.events"]},
    "developer.event-delivery": {"offline":"ServerOnly","dependencies":["developer.webhooks"]},
    "finance.posting-rules": {"offline":"ExportSeam","dependencies":["platform.events"]},
    "finance.bank-reconciliation": {"offline":"OnlineOnly","dependencies":["payment.reconciliation"]},
    "finance.cash-management": {"offline":"ExportSeam","dependencies":["commerce.cash-management"]}
  }
}
