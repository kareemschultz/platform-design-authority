{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.example.invalid/events/commerce.return.completed.v1.schema.json",
  "title": "commerce.return.completed.v1",
  "allOf": [
    {"$ref": "./event-envelope-v1.schema.json"},
    {
      "type": "object",
      "properties": {
        "name": {"const": "commerce.return.completed.v1"},
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": ["returnId", "saleId", "registerId", "approverPartyId", "lines", "mode"],
          "properties": {
            "returnId": {"type": "string"},
            "saleId": {"type": "string"},
            "registerId": {"type": "string"},
            "approverPartyId": {"type": "string"},
            "mode": {"type": "string", "enum": ["Return", "Void", "Exchange"]},
            "exchangeSaleId": {"type": ["string", "null"]},
            "lines": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["productId", "quantity"],
                "properties": {
                  "productId": {"type": "string"},
                  "variantId": {"type": ["string", "null"]},
                  "quantity": {"type": "string", "pattern": "^[0-9]+(\\.[0-9]{1,6})?$"}
                }
              }
            }
          }
        }
      }
    }
  ]
}
