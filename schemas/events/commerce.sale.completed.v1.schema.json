{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.example.invalid/events/commerce.sale.completed.v1.schema.json",
  "title": "commerce.sale.completed.v1",
  "allOf": [
    {"$ref": "./event-envelope-v1.schema.json"},
    {
      "type": "object",
      "properties": {
        "name": {"const": "commerce.sale.completed.v1"},
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": ["saleId", "registerId", "currency", "grossMinor", "discountMinor", "taxMinor", "totalMinor", "tenders", "receiptId", "completionMode"],
          "properties": {
            "saleId": {"type": "string"},
            "registerId": {"type": "string"},
            "customerPartyId": {"type": ["string", "null"]},
            "currency": {"type": "string", "pattern": "^[A-Z]{3}$"},
            "grossMinor": {"type": "integer"},
            "discountMinor": {"type": "integer"},
            "taxMinor": {"type": "integer"},
            "totalMinor": {"type": "integer"},
            "tenders": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["type", "amountMinor"],
                "properties": {
                  "type": {"type": "string", "enum": ["Cash", "PaymentIntent", "StoredValue"]},
                  "amountMinor": {"type": "integer"},
                  "referenceId": {"type": ["string", "null"]}
                }
              }
            },
            "receiptId": {"type": "string"},
            "completionMode": {"type": "string", "enum": ["Online", "Offline"]},
            "taxSnapshotVersion": {"type": ["string", "null"]}
          }
        }
      }
    }
  ]
}
