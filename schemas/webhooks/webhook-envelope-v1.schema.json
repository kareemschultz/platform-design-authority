{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.example.invalid/webhooks/webhook-envelope-v1.schema.json",
  "title": "Webhook Envelope V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["deliveryId", "attemptId", "event", "deliveredAt"],
  "properties": {
    "deliveryId": {"type": "string"},
    "attemptId": {"type": "string"},
    "deliveredAt": {"type": "string", "format": "date-time"},
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "occurredAt", "tenantId", "producer", "schemaVersion", "data"],
      "properties": {
        "id": {"type": "string"},
        "name": {"type": "string", "pattern": "^[a-z][a-z0-9-]*\\.[a-z][a-z0-9-]*\\.[a-z][a-z0-9-]*\\.v[1-9][0-9]*$"},
        "occurredAt": {"type": "string", "format": "date-time"},
        "publishedAt": {"type": ["string", "null"], "format": "date-time"},
        "tenantId": {"type": "string"},
        "organizationId": {"type": ["string", "null"]},
        "producer": {"type": "string"},
        "capabilityId": {"type": ["string", "null"]},
        "schemaVersion": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
        "correlationId": {"type": ["string", "null"]},
        "causationId": {"type": ["string", "null"]},
        "classification": {"type": "string"},
        "data": {"type": "object"}
      }
    }
  }
}
